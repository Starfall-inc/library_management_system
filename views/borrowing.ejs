<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Borrowing | Library System</title>
    <script src="https://cdn.tailwindcss.com"></script>
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css">
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700&display=swap" rel="stylesheet">
    <style>
        body { font-family: 'Inter', sans-serif; }
    </style>
</head>
<body class="bg-gray-50 flex min-h-screen">
    <%- include('partials/sidebar') %>

    <main class="flex-grow p-8">
        <header class="flex justify-between items-center mb-10">
            <div>
                <h1 class="text-3xl font-bold text-gray-900 tracking-tight">Borrowing Management</h1>
                <p class="text-gray-500 mt-1">Track book loans and handle returns.</p>
            </div>
            <button id="add-borrow-btn" class="bg-black text-white px-6 py-3 rounded-xl font-bold text-sm uppercase tracking-widest hover:bg-gray-900 transition-all flex items-center">
                <i class="fas fa-exchange-alt mr-2"></i> Issue Book
            </button>
        </header>

        <!-- Borrow Form Modal -->
        <div id="borrow-form-container" class="hidden fixed inset-0 bg-black bg-opacity-50 z-50 flex items-center justify-center p-4">
            <div class="bg-white w-full max-w-lg p-8 rounded-2xl shadow-2xl">
                <div class="flex justify-between items-center mb-8 border-b border-gray-100 pb-4">
                    <h2 class="text-xl font-bold text-gray-900 uppercase tracking-tight">Issue New Book</h2>
                    <button id="close-modal" class="text-gray-400 hover:text-black transition-colors">
                        <i class="fas fa-times text-xl"></i>
                    </button>
                </div>
                <form action="/borrowing" method="POST" class="space-y-6">
                    <div>
                        <label class="block text-xs font-semibold text-gray-700 uppercase tracking-wider mb-2">Select Member</label>
                        <select name="member_id" required class="w-full px-4 py-3 bg-gray-50 border border-gray-200 rounded-xl focus:outline-none focus:ring-2 focus:ring-black appearance-none">
                            <option value="">-- Choose Member --</option>
                            <% members.forEach(member => { %>
                                <option value="<%= member.id %>"><%= member.name %></option>
                            <% }); %>
                        </select>
                    </div>
                    <div>
                        <label class="block text-xs font-semibold text-gray-700 uppercase tracking-wider mb-2">Select Book</label>
                        <select name="book_id" required class="w-full px-4 py-3 bg-gray-50 border border-gray-200 rounded-xl focus:outline-none focus:ring-2 focus:ring-black appearance-none">
                            <option value="">-- Choose Book --</option>
                            <% books.forEach(book => { %>
                                <option value="<%= book.id %>"><%= book.title %> (<%= book.available_copies %> left)</option>
                            <% }); %>
                        </select>
                    </div>
                    <div class="flex gap-4 pt-4">
                        <button type="submit" class="flex-grow py-4 bg-black text-white rounded-xl font-bold text-sm uppercase tracking-widest hover:bg-gray-900 transition-all">Confirm Issue</button>
                        <button type="button" id="cancel-btn" class="flex-grow py-4 bg-gray-100 text-black rounded-xl font-bold text-sm uppercase tracking-widest hover:bg-gray-200 transition-all">Cancel</button>
                    </div>
                </form>
            </div>
        </div>

        <!-- Table -->
        <div class="bg-white rounded-2xl shadow-sm border border-gray-100 overflow-hidden">
            <table class="w-full text-left">
                <thead class="bg-gray-50 border-b border-gray-100">
                    <tr>
                        <th class="px-6 py-4 text-xs font-bold text-gray-500 uppercase tracking-wider">Book / Member</th>
                        <th class="px-6 py-4 text-xs font-bold text-gray-500 uppercase tracking-wider">Borrow Date</th>
                        <th class="px-6 py-4 text-xs font-bold text-gray-500 uppercase tracking-wider">Return Date</th>
                        <th class="px-6 py-4 text-xs font-bold text-gray-500 uppercase tracking-wider">Status</th>
                        <th class="px-6 py-4 text-xs font-bold text-gray-500 uppercase tracking-wider text-right">Actions</th>
                    </tr>
                </thead>
                <tbody class="divide-y divide-gray-50">
                    <% borrows.forEach(borrow => { %>
                        <tr class="hover:bg-gray-50 transition-colors group">
                            <td class="px-6 py-5">
                                <div class="font-bold text-gray-900"><%= borrow.book_title %></div>
                                <div class="text-sm text-gray-400 mt-0.5"><%= borrow.member_name %></div>
                            </td>
                            <td class="px-6 py-5 text-sm text-gray-600 font-medium">
                                <%= borrow.borrow_date %>
                            </td>
                            <td class="px-6 py-5 text-sm text-gray-500 italic">
                                <%= borrow.return_date || 'Pending...' %>
                            </td>
                            <td class="px-6 py-5">
                                <% if (borrow.status === 'borrowed') { %>
                                    <span class="px-3 py-1 bg-amber-50 text-amber-600 rounded-full text-[10px] font-bold uppercase border border-amber-100">Borrowed</span>
                                <% } else { %>
                                    <span class="px-3 py-1 bg-green-50 text-green-600 rounded-full text-[10px] font-bold uppercase border border-green-100">Returned</span>
                                <% } %>
                            </td>
                            <td class="px-6 py-5 text-right">
                                <% if (borrow.status === 'borrowed') { %>
                                    <form action="/borrowing/return/<%= borrow.id %>" method="POST">
                                        <button type="submit" class="text-xs font-bold text-black border-b-2 border-black hover:border-gray-400 transition-all uppercase tracking-tighter">Mark Returned</button>
                                    </form>
                                <% } else { %>
                                    <i class="fas fa-check-circle text-green-500"></i>
                                <% } %>
                            </td>
                        </tr>
                    <% }); %>
                    <% if (borrows.length === 0) { %>
                        <tr>
                            <td colspan="5" class="px-6 py-10 text-center text-gray-400 italic">No borrowing records found.</td>
                        </tr>
                    <% } %>
                </tbody>
            </table>
        </div>
    </main>

    <script>
        const addBorrowBtn = document.getElementById('add-borrow-btn');
        const borrowFormContainer = document.getElementById('borrow-form-container');
        const closeModal = document.getElementById('close-modal');
        const cancelBtn = document.getElementById('cancel-btn');

        addBorrowBtn.addEventListener('click', () => {
            borrowFormContainer.classList.remove('hidden');
        });

        const closeForm = () => borrowFormContainer.classList.add('hidden');
        closeModal.addEventListener('click', closeForm);
        cancelBtn.addEventListener('click', closeForm);
    </script>
</body>
</html>
